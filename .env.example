# ============================================================
# GUZEM - Gerekli Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env dosyası asla Git'e eklenmemelidir (.gitignore'a ekli).
# ============================================================

# ===== Veritabanı =====
DB_PASSWORD=your_mssql_password_here

# ===== Zoom OAuth =====
# Zoom Marketplace → Server-to-Server OAuth uygulamanızdan alın
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# ===== E-Posta (SMTP) =====
# Production için gerçek SMTP bilgileri gereklidir
MAIL_USERNAME=noreply@gazi.edu.tr
MAIL_PASSWORD=your_smtp_app_password

# Mail gönderimini etkinleştirmek için true yapın
MAIL_ENABLED=false
